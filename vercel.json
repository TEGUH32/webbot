{
  "version": 2,
  "functions": {
    "api/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/public/index.html" }
  ],
  "env": {
    "BOT_API_URL": "@bot_api_url",
    "API_KEY": "@bot_api_key"
  }
}
